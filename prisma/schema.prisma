generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Department {
  Id             Int       @id(map: "PK__Departme__3214EC07E48D2274") @default(autoincrement())
  Name           String    @db.VarChar(100)
  Code           String    @db.VarChar(20)
  CreatedAt      DateTime? @default(now(), map: "DF__Departmen__Creat__5AEE82B9") @db.DateTime
  UpdatedAt      DateTime? @db.DateTime
  IsMarkToDelete Boolean   @default(false, map: "DF__Departmen__IsMar__5BE2A6F2")
  Batches        Batches[]
  Papers         Papers[]
  Users          Users[]
}

model Roles {
  Id    Int     @id(map: "PK__Roles__3214EC0762290ED5") @default(autoincrement())
  Name  String  @db.NVarChar(50)
  Users Users[]
}

model Users {
  Id             Int           @id(map: "PK__Users__3214EC07DCAE69D8") @default(autoincrement())
  Name           String        @db.VarChar(100)
  Email          String        @db.VarChar(150)
  StudentId      String        @db.VarChar(150)
  Password       String        @db.VarChar(Max)
  DepartmentId   Int
  RoleId         Int?
  IsMarkToDelete Boolean?
  CreatedAt      DateTime?     @db.DateTime
  UpdatedAt      DateTime?     @db.DateTime
  PaperGroups    PaperGroups[]
  Papers         Papers[]
  Department     Department    @relation(fields: [DepartmentId], references: [Id], onUpdate: NoAction, map: "FK_Users_Department")
  Roles          Roles?        @relation(fields: [RoleId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Users_Roles")
}

model UserSessions {
  Id             String    @id(map: "PK__UserSess__3214EC07018A5C07") @db.NVarChar(36)
  UserId         String    @db.NVarChar(36)
  RefreshtokenId String    @unique(map: "UQ__UserSess__F147A8DFE4704B58") @db.NVarChar(36)
  IsActive       Boolean?  @default(false, map: "DF__UserSessi__IsAct__70DDC3D8")
  CreatedDate    DateTime? @default(now(), map: "DF__UserSessi__Creat__71D1E811") @db.DateTime
}

model Batches {
  Id             Int        @id(map: "PK__Batches__3214EC0733399ACD") @default(autoincrement())
  Name           String     @db.NVarChar(100)
  Year           Int
  DepartmentId   Int
  CreatedAt      DateTime   @default(now(), map: "DF__Batches__Created__571DF1D5")
  UpdatedAt      DateTime?
  CreatedBy      String?    @db.NVarChar(Max)
  UpdatedBy      String?    @db.NVarChar(Max)
  IsMarkToDelete Boolean    @default(false, map: "DF__Batches__IsMarkT__5812160E")
  Department     Department @relation(fields: [DepartmentId], references: [Id], onUpdate: NoAction, map: "FK_Batches_Department")
  Papers         Papers[]
}

model Category {
  Id             Int           @id(map: "PK__Category__3214EC0732DEE161") @default(autoincrement())
  Name           String        @db.NVarChar(100)
  Code           String?       @db.NVarChar(50)
  IsMarkToDelete Boolean       @default(false, map: "DF__Category__IsMark__59063A47")
  CreatedAt      DateTime      @default(now(), map: "DF__Category__Create__59FA5E80")
  UpdatedAt      DateTime?
  CreatedBy      String?       @db.NVarChar(Max)
  UpdatedBy      String?       @db.NVarChar(Max)
  Papers         Papers[]
  SubCategory    SubCategory[]
}

model SubCategory {
  Id             Int       @id(map: "PK__SubCateg__3214EC07DD4BDFB6") @default(autoincrement())
  Name           String    @db.NVarChar(100)
  Code           String?   @db.NVarChar(50)
  IsMarkToDelete Boolean   @default(false, map: "DF__SubCatego__IsMar__5CD6CB2B")
  CategoryId     Int
  CreatedAt      DateTime? @default(now(), map: "DF__SubCatego__Creat__5DCAEF64")
  UpdatedAt      DateTime?
  CreatedBy      String    @db.NVarChar(Max)
  UpdatedBy      String?   @db.NVarChar(Max)
  Papers         Papers[]
  Category       Category  @relation(fields: [CategoryId], references: [Id], onUpdate: NoAction, map: "FK_SubCategory_Category")
}

model Papers {
  Id             Int           @id(map: "PK__Papers__3214EC0774695817") @default(autoincrement())
  Title          String?       @db.VarChar(Max)
  Abstract       String?       @db.VarChar(Max)
  UserId         Int?
  CategoryId     Int?
  SubcategoryId  Int?
  DepartmentId   Int?
  BatchId        Int?
  Year           DateTime?     @default(now(), map: "DF__Papers__Year__09A971A2") @db.DateTime
  FileUrl        String?       @db.VarChar(Max)
  IsMarkToDelete Boolean?
  CreatedDate    DateTime?     @default(now(), map: "DF__Papers__CreatedD__0A9D95DB") @db.DateTime
  UpdatedDate    DateTime?     @db.DateTime
  CreatedBy      String?       @db.VarChar(Max)
  UpdatedBy      String?       @db.VarChar(Max)
  PaperGroups    PaperGroups[]
  Batches        Batches?      @relation(fields: [BatchId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Papers__BatchId__2CF2ADDF")
  Category       Category?     @relation(fields: [CategoryId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Papers__Category__2A164134")
  Department     Department?   @relation(fields: [DepartmentId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Papers__Departme__2BFE89A6")
  SubCategory    SubCategory?  @relation(fields: [SubcategoryId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Papers__Subcateg__2B0A656D")
  Users          Users?        @relation(fields: [UserId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Papers__UserId__29221CFB")
}

model PaperGroups {
  Id             Int       @id(map: "PK__PaperGro__3214EC0710011553") @default(autoincrement())
  PaperId        Int?
  UserType       String?   @db.VarChar(Max)
  UserId         Int?
  IsMarkToDelete Boolean?
  CreatedDate    DateTime? @default(now(), map: "DF__PaperGrou__Creat__0F624AF8") @db.DateTime
  UpdatedDate    DateTime? @db.DateTime
  CreatedBy      String?   @db.VarChar(Max)
  UpdatedBy      String?   @db.VarChar(Max)
  Papers         Papers?   @relation(fields: [PaperId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__PaperGrou__Paper__0D7A0286")
  Users          Users?    @relation(fields: [UserId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__PaperGrou__UserI__0E6E26BF")
}
