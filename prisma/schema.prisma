generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Department {
  Id             Int       @id(map: "PK__Departme__3214EC0708605120") @default(autoincrement())
  Name           String    @db.VarChar(100)
  Code           String    @db.VarChar(20)
  CreatedAt      DateTime? @default(now(), map: "DF__Departmen__Creat__4CA06362") @db.DateTime
  UpdatedAt      DateTime? @db.DateTime
  IsMarkToDelete Boolean   @default(false, map: "DF__Departmen__IsMar__70DDC3D8")
  Batches        Batches[]
  Papers         Papers[]
  Users          Users[]
}

model Roles {
  Id    Int     @id(map: "PK__Roles__3214EC07F35EAD1B") @default(autoincrement())
  Name  String  @db.NVarChar(50)
  Users Users[]
}

model Users {
  Id             Int          @id(map: "PK__Users__3214EC073D9CAFDD") @default(autoincrement())
  Name           String       @db.VarChar(100)
  Email          String       @db.VarChar(150)
  StudentId      String       @db.VarChar(150)
  Password       String       @db.VarChar(Max)
  DepartmentId   Int
  RoleId         Int?
  IsMarkToDelete Boolean?
  CreatedAt      DateTime?    @db.DateTime
  UpdatedAt      DateTime?    @db.DateTime
  BatchId        Int?
  PaperGroup     PaperGroup[]
  Papers         Papers[]
  Batches        Batches?     @relation(fields: [BatchId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Users_Batches")
  Department     Department   @relation(fields: [DepartmentId], references: [Id], onUpdate: NoAction, map: "FK_Users_Department")
  Roles          Roles?       @relation(fields: [RoleId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Users_Roles")
}

model UserSessions {
  Id             String    @id(map: "PK__UserSess__3214EC07018A5C07") @db.NVarChar(36)
  UserId         String    @db.NVarChar(36)
  RefreshtokenId String    @unique(map: "UQ__UserSess__F147A8DFE4704B58") @db.NVarChar(36)
  IsActive       Boolean?  @default(false, map: "DF__UserSessi__IsAct__70DDC3D8")
  CreatedDate    DateTime? @default(now(), map: "DF__UserSessi__Creat__71D1E811") @db.DateTime
}

model Batches {
  Id             Int        @id(map: "PK__Batches__3214EC07370B787A") @default(autoincrement())
  Name           String     @db.NVarChar(100)
  Year           Int
  DepartmentId   Int
  CreatedAt      DateTime   @default(now(), map: "DF__Batches__Created__02FC7413")
  UpdatedAt      DateTime?
  CreatedBy      String?    @db.NVarChar(Max)
  UpdatedBy      String?    @db.NVarChar(Max)
  IsMarkToDelete Boolean    @default(false, map: "DF__Batches__IsMarkT__0D7A0286")
  Department     Department @relation(fields: [DepartmentId], references: [Id], onUpdate: NoAction, map: "FK_Batches_Department")
  Papers         Papers[]
  Users          Users[]
}

model Category {
  Id             Int           @id(map: "PK__Category__3214EC07740925E0") @default(autoincrement())
  Name           String        @db.NVarChar(100)
  Code           String?       @db.NVarChar(50)
  IsMarkToDelete Boolean       @default(false, map: "DF__Category__IsMark__06CD04F7")
  CreatedAt      DateTime      @default(now(), map: "DF__Category__Create__07C12930")
  UpdatedAt      DateTime?
  CreatedBy      String?       @db.NVarChar(Max)
  UpdatedBy      String?       @db.NVarChar(Max)
  Papers         Papers[]
  SubCategory    SubCategory[]
}

model SubCategory {
  Id             Int       @id(map: "PK__SubCateg__3214EC0799321578") @default(autoincrement())
  Name           String    @db.NVarChar(100)
  Code           String?   @db.NVarChar(50)
  IsMarkToDelete Boolean   @default(false, map: "DF__SubCatego__IsMar__0A9D95DB")
  CategoryId     Int
  CreatedAt      DateTime? @default(now(), map: "DF__SubCatego__Creat__0B91BA14")
  UpdatedAt      DateTime?
  CreatedBy      String    @db.NVarChar(Max)
  UpdatedBy      String?   @db.NVarChar(Max)
  Papers         Papers[]
  Category       Category  @relation(fields: [CategoryId], references: [Id], onUpdate: NoAction, map: "FK_SubCategory_Category")
}

model Papers {
  Id             Int          @id(map: "PK__Papers__3214EC07F8A04F5C") @default(autoincrement())
  Title          String?      @db.VarChar(Max)
  Abstract       String?      @db.VarChar(Max)
  UserId         Int?
  CategoryId     Int?
  SubcategoryId  Int?
  DepartmentId   Int?
  BatchId        Int?
  Year           String?      @db.VarChar(Max)
  FileUrl        String?      @db.VarChar(Max)
  CreatedDate    DateTime?    @default(now(), map: "DF__Papers__CreatedD__2DE6D218") @db.DateTime
  UpdatedDate    DateTime?    @db.DateTime
  CreatedBy      String?      @db.VarChar(Max)
  UpdatedBy      String?      @db.VarChar(Max)
  IsMarkToDelete Boolean?     @default(false, map: "DF__Papers__IsMarkTo__4D5F7D71")
  PaperGroup     PaperGroup[]
  Batches        Batches?     @relation(fields: [BatchId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Papers__BatchId__2CF2ADDF")
  Category       Category?    @relation(fields: [CategoryId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Papers__Category__2A164134")
  Department     Department?  @relation(fields: [DepartmentId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Papers__Departme__2BFE89A6")
  SubCategory    SubCategory? @relation(fields: [SubcategoryId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Papers__Subcateg__2B0A656D")
  Users          Users?       @relation(fields: [UserId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__Papers__UserId__29221CFB")
}

model PaperGroup {
  Id          Int       @id(map: "PK__PaperGro__3214EC070B95F17F") @default(autoincrement())
  PaperId     Int?
  UserType    String?   @db.VarChar(Max)
  UserId      Int?
  CreatedDate DateTime? @default(now(), map: "DF__PaperGrou__Creat__32AB8735") @db.DateTime
  UpdatedDate DateTime? @db.DateTime
  CreatedBy   String?   @db.VarChar(Max)
  UpdatedBy   String?   @db.VarChar(Max)
  Papers      Papers?   @relation(fields: [PaperId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__PaperGrou__Paper__30C33EC3")
  Users       Users?    @relation(fields: [UserId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK__PaperGrou__UserI__31B762FC")
}
